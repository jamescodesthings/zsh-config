#!/usr/bin/env zsh

source "${0:a:h}/_stub"

if is available asdf; then
  if is equal "$1" "--force"; then
    echo "$c[info]reinstalling:$c[reset] asdf (--force)"
  else
    echo "$c[info]skipping:$c[reset] asdf already installed"
    exit 0
  fi
fi

if is available brew; then
  if is equal "$1" "--force"; then
    echo "$c[info]reinstalling:$c[reset] asdf via homebrew"
    brew reinstall asdf
    if is not equal "$?" "0"; then
      echo "$c[error]error:$c[reset] homebrew reinstall failed"
      echo "try: $c[em]brew reinstall asdf$c[reset]"
      exit 1
    fi
    echo "$c[success]success:$c[reset] asdf reinstalled via homebrew"
    exit 0
  fi

  echo "$c[info]installing:$c[reset] asdf via homebrew"
  brew install asdf
  if is not equal "$?" "0"; then
    echo "$c[error]error:$c[reset] homebrew install failed"
    echo "try: $c[em]brew install asdf$c[reset]"
    exit 1
  fi
  echo "$c[success]success:$c[reset] asdf installed via homebrew"
  exit 0
fi

if is linux; then
  echo "$c[error]error:$c[reset] asdf is not available via package manager on linux"
  echo "$c[info]install instructions:$c[reset] https://asdf-vm.com/guide/getting-started.html"
  exit 1
fi

echo "$c[error]error:$c[reset] no supported package manager found (brew or apt)"
echo "$c[info]install instructions:$c[reset] https://asdf-vm.com/guide/getting-started.html"
exit 1

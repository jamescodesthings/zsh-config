#!/usr/bin/env zsh

source "${0:a:h}/_stub"

check-or-load get-hostname
check-or-load install-link

if is not equal "$(get-hostname)" "ubuntu"; then
  echo "$c[info]skipping:$c[reset] gnome-extension-window-list is only for the ubuntu machine"
  exit 0
fi

EXT_UUID="window-list@personal"
EXT_SRC="$REPO_DIR/configs/gnome/$EXT_UUID"
EXT_DEST="$HOME/.local/share/gnome-shell/extensions/$EXT_UUID"

echo "$c[info]installing:$c[reset] GNOME extension $EXT_UUID"

mkdir -p "$HOME/.local/share/gnome-shell/extensions"
install-link "$EXT_SRC" "$EXT_DEST" || exit 1

if command -v gnome-extensions &>/dev/null; then
  if gnome-extensions enable "$EXT_UUID" 2>/dev/null; then
    echo "$c[success]enabled:$c[reset] $EXT_UUID"
  else
    echo "$c[warn]note:$c[reset] could not auto-enable — run manually: gnome-extensions enable $EXT_UUID"
  fi
else
  echo "$c[warn]note:$c[reset] gnome-extensions not found — enable manually: gnome-extensions enable $EXT_UUID"
fi

echo "$c[warn]reload:$c[reset] log out and back in (Wayland — no in-place shell restart)"
echo "$c[success]success:$c[reset] gnome-extension-window-list install complete"

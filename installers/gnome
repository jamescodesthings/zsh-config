#!/usr/bin/env zsh

source "${0:a:h}/_stub"

check-or-load install-link

if is tty; then
  echo "$c[info]skipping:$c[reset] gnome cannot be installed from a terminal session (no display)"
  exit 0
fi

if is not gnome || is not wayland; then
  echo "$c[info]skipping:$c[reset] gnome installer requires GNOME on Wayland (XDG_CURRENT_DESKTOP=$XDG_CURRENT_DESKTOP, XDG_SESSION_TYPE=$XDG_SESSION_TYPE)"
  exit 0
fi

EXT_UUID="window-list@personal"
EXT_SRC="$REPO_DIR/configs/gnome/$EXT_UUID"
EXT_DEST="$HOME/.local/share/gnome-shell/extensions/$EXT_UUID"

echo "$c[info]installing:$c[reset] GNOME extension $EXT_UUID"
mkdir -p "$HOME/.local/share/gnome-shell/extensions"
install-link "$EXT_SRC" "$EXT_DEST" || exit 1

if command -v gnome-extensions &>/dev/null; then
  if gnome-extensions enable "$EXT_UUID" 2>/dev/null; then
    echo "$c[success]enabled:$c[reset] $EXT_UUID"
  else
    echo "$c[warn]note:$c[reset] could not auto-enable — run manually: gnome-extensions enable $EXT_UUID"
  fi
else
  echo "$c[warn]note:$c[reset] gnome-extensions not found — enable manually: gnome-extensions enable $EXT_UUID"
fi

BIN_SRC="$REPO_DIR/configs/gnome/bin"
BIN_DEST="/usr/local/bin"
mkdir -p "$BIN_DEST"
echo "$c[info]installing:$c[reset] gnome bin scripts → $BIN_DEST"
chmod +x "$BIN_SRC"/*
for script in "$BIN_SRC"/*; do
  name=$(basename "$script")
  install-link "$script" "$BIN_DEST/$name" || exit 1
done

DESKTOP_SRC="$REPO_DIR/configs/gnome/quit-all-apps.desktop"
DESKTOP_DEST="$HOME/.local/share/applications/quit-all-apps.desktop"
mkdir -p "$HOME/.local/share/applications"
echo "$c[info]installing:$c[reset] quit-all-apps desktop entry"
install-link "$DESKTOP_SRC" "$DESKTOP_DEST" || exit 1

echo "$c[warn]reload:$c[reset] log out and back in (Wayland — no in-place shell restart)"
echo "$c[success]success:$c[reset] gnome install complete"

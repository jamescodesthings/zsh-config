#!/usr/bin/env zsh
source "${0:a:h}/_stub"

if is not available tldr; then
  echo "$c[info]skipping:$c[reset] tldr not installed"
  exit 0
fi

echo "$c[info]updating:$c[reset] tldr cache"
tldr --update
if is not equal "$?" "0"; then
  echo "$c[error]error:$c[reset] tldr update failed"
  exit 1
fi

echo "$c[success]success:$c[reset] tldr updated"

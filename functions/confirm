#!/usr/bin/env zsh

function confirm() {
  if is equal "$1" "--help"; then
    echo "$c[h1]confirm$c[reset]"
    echo ""
    echo "$c[lead]prompts for yes/no confirmation. returns 0 if confirmed, 1 if denied.$c[reset]"
    echo ""
    echo "$c[h2]usage$c[reset]"
    echo "  confirm $c[param][message]$c[reset]"
    echo ""
    echo "$c[h2]examples$c[reset]"
    echo "  confirm"
    echo "  confirm $c[param]'are you sure you want to delete this?'$c[reset]"
    echo ""
    echo "$c[h2]in a script$c[reset]"
    echo "  $c[sub]if$c[reset] confirm $c[param]'are you sure?'$c[reset]$c[sub]; then$c[reset]"
    echo "    $c[em]# do the thing$c[reset]"
    echo "  $c[sub]fi$c[reset]"
    return 0
  fi

  local MESSAGE=${1:="$c[warn]are you sure?$c[reset]"}
  read "confirmed?$MESSAGE $c[sub][y/n]$c[reset] "
  if [[ "$confirmed" =~ ^[Yy]$ ]]; then
    return 0
  else
    return 1
  fi
}

confirm "$@"

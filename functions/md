#!/usr/bin/env zsh

function md() {
  local DEPS=(is)
  if ! deps $DEPS; then
    return 1
  fi

  if is equal "$1" "--help" || is empty "$1"; then
    echo "$c[h1]md$c[reset]"
    echo ""
    echo "$c[lead]makes a directory and immediately cds into it.$c[reset]"
    echo ""
    echo "$c[h2]usage$c[reset]"
    echo "  md $c[flag][--no-follow]$c[reset] $c[param]<path>$c[reset]"
    echo ""
    echo "$c[h2]flags$c[reset]"
    echo "  $c[flag]--no-follow$c[reset]    create the directory without changing into it"
    echo ""
    echo "$c[h2]examples$c[reset]"
    echo "  md $c[param]new-project$c[reset]"
    echo "  md $c[flag]--no-follow$c[reset] $c[param]src/components$c[reset]"
    return 0
  fi

  local NO_FOLLOW=0
  local DIRPATH

  if is equal "$1" "--no-follow"; then
    NO_FOLLOW=1
    DIRPATH="$2"
  else
    DIRPATH="$1"
  fi

  if is empty "$DIRPATH"; then
    echo "$c[error]error:$c[reset] no path provided"
    return 1
  fi

  mkdir -p "$DIRPATH"
  if is not equal "$?" "0"; then
    echo "$c[error]error:$c[reset] could not create $DIRPATH"
    return 1
  fi

  if is equal $NO_FOLLOW 0; then
    cd "$DIRPATH"
    echo "$c[success]success:$c[reset] created $DIRPATH"
  else
    echo "$c[success]success:$c[reset] created $DIRPATH (no follow)"
  fi
}

md "$@"

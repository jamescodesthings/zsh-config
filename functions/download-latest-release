#!/usr/bin/env zsh

function download-latest-release() {
  if is not equal "$#" "1" || is equal "$1" "--help"; then
    echo "$c[h1]download-latest-release$c[reset]"
    echo ""
    echo "$c[lead]downloads the latest release asset from a github repository matching the current os and architecture.$c[reset]"
    echo ""
    echo "$c[h2]usage$c[reset]"
    echo "  download-latest-release $c[param]<owner>/<repo>$c[reset]"
    echo ""
    echo "$c[h2]examples$c[reset]"
    echo "  download-latest-release $c[param]asdf-vm/asdf$c[reset]"
    return 1
  fi

  local OWNER=$(echo "$1" | cut -d '/' -f 1)
  local REPO=$(echo "$1" | cut -d '/' -f 2)

  echo "$c[info]fetching:$c[reset] latest release for $OWNER/$REPO"

  local LATEST_RELEASE=$(curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')
  if is empty "$LATEST_RELEASE"; then
    echo "$c[error]error:$c[reset] could not fetch latest release for $OWNER/$REPO" >&2
    return 1
  fi
  echo "$c[info]found:$c[reset] $LATEST_RELEASE"

  local ARCH=$(uname -m)
  if is empty "$ARCH"; then
    echo "$c[error]error:$c[reset] could not determine architecture" >&2
    return 1
  fi

  local KERNEL=$(uname -s | tr '[:upper:]' '[:lower:]')
  if is empty "$KERNEL"; then
    echo "$c[error]error:$c[reset] could not determine kernel" >&2
    return 1
  fi

  echo "$c[info]detecting:$c[reset] $KERNEL/$ARCH"

  local ASSET_URL=$(curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" | grep "browser_download_url" | grep -v ".md5" | grep "$KERNEL-$ARCH" | cut -d '"' -f 4)
  if is empty "$ASSET_URL"; then
    echo "$c[error]error:$c[reset] no asset found for $KERNEL-$ARCH" >&2
    echo "$c[info]available urls:$c[reset]"
    curl -s "https://api.github.com/repos/$OWNER/$REPO/releases/latest" | grep "browser_download_url" | grep -v ".md5" | cut -d '"' -f 4
    return 1
  fi

  local ASSET_NAME=$(basename "$ASSET_URL")
  local INSTALL_DIR="$CUSTOM_DIR/.installers"
  mkdir -p "$INSTALL_DIR"
  local ASSET_PATH="$INSTALL_DIR/$ASSET_NAME"

  echo "$c[info]downloading:$c[reset] $ASSET_NAME"
  curl -L "$ASSET_URL" -o "$ASSET_PATH"
  if [[ $? -ne 0 ]]; then
    echo "$c[error]error:$c[reset] download failed from $ASSET_URL" >&2
    return 1
  fi

  echo "$c[success]success:$c[reset] downloaded to $ASSET_PATH"
}

download-latest-release "$@"

#!/usr/bin/env zsh

function _cheat_expand_vars() {
  local file="$1"
  awk '
    function expand_vars(s,    result, rest, tok, name, val) {
      result = ""
      rest = s
      while (match(rest, /\$\{?[A-Za-z_][A-Za-z0-9_]*\}?/)) {
        result = result substr(rest, 1, RSTART-1)
        tok  = substr(rest, RSTART, RLENGTH)
        rest = substr(rest, RSTART+RLENGTH)
        name = tok; gsub(/[${}]/, "", name)
        val  = ENVIRON[name]
        result = result (val != "" ? val : tok)
      }
      return result rest
    }
    /^```/ { fence = !fence; print; next }
    fence  { print; next }
    {
      line = $0; out = ""
      n = split(line, parts, "`")
      for (i = 1; i <= n; i++) {
        if (i % 2 == 1 || (i == n && n % 2 == 0)) {
          out = out expand_vars(parts[i])
        } else {
          out = out "`" parts[i] "`"
        }
      }
      print out
    }
  ' "$file"
}

function cheat() {
  if is empty "$CHEATSHEET_DIR"; then
    echo "${c[error]}error:${c[reset]} CHEATSHEET_DIR not set, run zsh-config/install to install it"
    return 1
  fi

  # Renderer: tldr → glow → bat → cat
  local render_cmd render_args=()
  if is available tldr; then
    render_cmd="tldr"; render_args=("--render")
  elif is available glow; then
    render_cmd="glow"; render_args=("-w" "120")
  elif is available bat; then
    render_cmd="bat"; render_args=("-p" "--color=always")
  else
    render_cmd="cat"
  fi

  # Auto-update tldr cache (silent, background, every 7 days)
  if is available tldr; then
    local _stamp="$CHEATSHEET_DIR/.tldr-last-update"
    local _now; _now=$(date +%s)
    local _last=0
    is file "$_stamp" && _last=$(cat "$_stamp" 2>/dev/null || echo 0)
    if (( _now - _last > 604800 )); then
      tldr --update &>/dev/null &!
      echo "$_now" >| "$_stamp"
    fi
  fi

  # No args → list
  if [[ $# -eq 0 ]]; then
    echo "${c[h1]}Local Cheatsheets:${c[reset]}"
    for f in "$CHEATSHEET_DIR"/*.md(N); do
      echo "  $(basename "$f" .md)"
    done | sort
    return 0
  fi

  local subcmd="$1"
  shift

  case "$subcmd" in

    -h|--help|help)
      echo "${c[h1]}cheat${c[reset]}"
      echo ""
      echo "${c[lead]}Personal cheatsheet viewer with tldr fallback. Cheatsheets live in \$CHEATSHEET_DIR.${c[reset]}"
      echo ""
      echo "${c[h2]}Usage:${c[reset]}"
      echo "  cheat                          list all local cheatsheets"
      echo "  cheat ${c[param]}<name>${c[reset]}                   show a cheatsheet"
      echo "  cheat ${c[param]}<word> <word>${c[reset]}             multi-word: 'cheat git commit' → git-commit.md"
      echo "  cheat ${c[param]}<name>${c[reset]} ${c[flag]}--raw${c[reset]}              print raw markdown"
      echo ""
      echo "${c[h2]}Subcommands:${c[reset]}"
      echo "  ${c[flag]}list${c[reset]}                           list local cheatsheets"
      echo "  ${c[flag]}search${c[reset]} ${c[param]}<query>${c[reset]}                search local + tldr by name"
      echo "  ${c[flag]}edit${c[reset]} ${c[param]}<name>${c[reset]}                  open in \$EDITOR"
      echo "  ${c[flag]}new${c[reset]} ${c[param]}<name>${c[reset]}                   create from template"
      echo "  ${c[flag]}update${c[reset]}                         update tldr cache"
      echo "  ${c[flag]}raw${c[reset]} ${c[param]}<name>${c[reset]}                   print raw markdown"
      echo "  ${c[flag]}help${c[reset]}, ${c[flag]}-h${c[reset]}, ${c[flag]}--help${c[reset]}             show this help"
      ;;

    list)
      echo "${c[h1]}Local Cheatsheets:${c[reset]}"
      for f in "$CHEATSHEET_DIR"/*.md(N); do
        echo "  $(basename "$f" .md)"
      done | sort
      ;;

    search)
      local query="$1"
      if is empty "$query"; then
        echo "${c[error]}error:${c[reset]} search requires a query"
        return 1
      fi
      local -a local_results=() tldr_only=()
      for f in "$CHEATSHEET_DIR"/*.md(N); do
        local name; name=$(basename "$f" .md)
        [[ "$name" == *"$query"* ]] && local_results+=("$name")
      done
      if is available tldr; then
        while IFS= read -r page; do
          is empty "$page" && continue
          (( ${local_results[(Ie)$page]} )) || tldr_only+=("$page")
        done < <(tldr --list-all 2>/dev/null | grep -i "$query" | sort)
      fi
      if (( ${#local_results[@]} + ${#tldr_only[@]} > 0 )); then
        for r in "${local_results[@]}"; do
          printf "  %-30s %s\n" "$r" "${c[success]}[cheatsheet]${c[reset]}"
        done
        for r in "${tldr_only[@]}"; do
          printf "  %-30s %s\n" "$r" "${c[info]}[tldr]${c[reset]}"
        done
      else
        echo "${c[warn]}nothing found for \"$query\"${c[reset]}"
      fi
      ;;

    edit)
      if is empty "$1"; then
        echo "${c[error]}error:${c[reset]} edit requires a sheet name"
        return 1
      fi
      local sheet_name="${(j:-:)@}"
      sheet_name="${sheet_name%.md}"
      local edit_file="$CHEATSHEET_DIR/$sheet_name.md"
      if ! is file "$edit_file"; then
        echo "${c[error]}error:${c[reset]} '$sheet_name' not found — use ${c[flag]}cheat new $sheet_name${c[reset]} to create it"
        return 1
      fi
      ${EDITOR:-micro} "$edit_file"
      ;;

    new)
      if is empty "$1"; then
        echo "${c[error]}error:${c[reset]} new requires a name"
        return 1
      fi
      local new_name="${1%.md}"
      local new_file="$CHEATSHEET_DIR/$new_name.md"
      if is file "$new_file"; then
        echo "${c[error]}error:${c[reset]} '$new_name' already exists — use ${c[flag]}cheat edit $new_name${c[reset]} to edit it"
        return 1
      fi
      cat >| "$new_file" <<TEMPLATE
# $new_name

Short description.

## Usage

- Example:

\`command --flag arg\`

## Related commands

- Related tool
\`cheat related-name\`
TEMPLATE
      echo "${c[success]}created:${c[reset]} cheatsheets/$new_name.md"
      echo "run ${c[flag]}cheat edit $new_name${c[reset]} to fill it in"
      ;;

    update)
      if ! is available tldr; then
        echo "${c[warn]}warn:${c[reset]} tldr not available"
        return 1
      fi
      tldr --update
      date +%s >| "$CHEATSHEET_DIR/.tldr-last-update"
      ;;

    raw)
      local raw_name="${(j:-:)@}"
      raw_name="${raw_name%.md}"
      if is empty "$raw_name"; then
        echo "${c[error]}error:${c[reset]} raw requires a sheet name"
        return 1
      fi
      if is file "$CHEATSHEET_DIR/$raw_name.md"; then
        cat "$CHEATSHEET_DIR/$raw_name.md"
      elif is available tldr; then
        tldr --raw "$raw_name"
      else
        echo "${c[error]}error:${c[reset]} '$raw_name' not found"
        return 1
      fi
      ;;

    *)
      # Not a known subcommand — treat all args as sheet name (join with -)
      local -a name_parts=("$subcmd" "$@")
      local raw_mode=0
      local -a clean_parts=()
      for part in "${name_parts[@]}"; do
        [[ "$part" == "--raw" ]] && raw_mode=1 || clean_parts+=("$part")
      done
      local sheet_name="${(j:-:)clean_parts}"
      sheet_name="${sheet_name%.md}"

      if (( raw_mode )); then
        if is file "$CHEATSHEET_DIR/$sheet_name.md"; then
          cat "$CHEATSHEET_DIR/$sheet_name.md"
        elif is available tldr; then
          tldr --raw "$sheet_name"
        else
          echo "${c[error]}error:${c[reset]} '$sheet_name' not found"
          return 1
        fi
      else
        if is file "$CHEATSHEET_DIR/$sheet_name.md"; then
          local _cheat_tmp; _cheat_tmp=$(mktemp)
          _cheat_expand_vars "$CHEATSHEET_DIR/$sheet_name.md" > "$_cheat_tmp"
          $render_cmd "${render_args[@]}" "$_cheat_tmp"
          rm -f "$_cheat_tmp"
        elif is available tldr; then
          tldr "$sheet_name"
        else
          echo "${c[error]}error:${c[reset]} '$sheet_name' not found and tldr is not available"
          return 1
        fi
      fi
      ;;
  esac
}

cheat "$@"

#!/usr/bin/env zsh

function install-link() {
  if is not equal "$#" "2" || is equal "$1" "--help"; then
    echo "$c[h1]install-link$c[reset]"
    echo ""
    echo "$c[lead]creates a symlink from a source path to a target path, backing up any existing file.$c[reset]"
    echo ""
    echo "$c[h2]usage$c[reset]"
    echo "  install-link $c[param]<from>$c[reset] $c[param]<to>$c[reset]"
    echo ""
    echo "$c[h2]examples$c[reset]"
    echo "  install-link $c[param]./configs/asdf/.asdfrc$c[reset] $c[param]~/.asdfrc$c[reset]"
    return 1
  fi

  local FROM="$1"
  local TO="$2"

  if is link "$TO"; then
    echo "$c[info]removing:$c[reset] existing link $TO"
    sudo rm "$TO"
    if is not equal "$?" "0"; then
      echo "$c[error]error:$c[reset] could not remove existing link $TO"
      return 1
    fi
  fi

  if is file "$TO"; then
    echo "$c[info]backing up:$c[reset] $TO → $TO.bak"
    sudo mv "$TO" "$TO.bak"
    if is not equal "$?" "0"; then
      echo "$c[error]error:$c[reset] could not back up existing file $TO"
      return 1
    fi
  fi

  if is dir "$TO"; then
    echo "$c[info]backing up:$c[reset] $TO → ${TO}_bak"
    sudo mv "$TO" "${TO}_bak"
    if is not equal "$?" "0"; then
      echo "$c[error]error:$c[reset] could not back up existing directory $TO"
      return 1
    fi
  fi

  echo "$c[info]linking:$c[reset] $FROM → $TO"
  sudo ln -s "$FROM" "$TO"
  if is not equal "$?" "0"; then
    echo "$c[error]error:$c[reset] could not create link $FROM → $TO"
    return 1
  fi
}

install-link "$@"

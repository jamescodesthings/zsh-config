#!/usr/bin/env zsh

# gcod: Checks out development (git flow configured)
function gcod () {
  local DEPS=(
    git
  )

  if ! deps $DEPS; then
    return
  fi

  DEV_BRANCH=$(git config gitflow.branch.develop)
  if is empty "$DEV_BRANCH"; then
    return 1
  fi

  git checkout $DEV_BRANCH
    if is not equal "$?" "0"; then
    echo "$c[error]Could not checkout development branch ($DEV_BRANCH)\n$c[reset]"
    echo "$c[sub]to set the development branch for this repo:$c[reset]"
    echo "git config gitflow.branch.develop $c[flag]develop$c[reset]"
    return 1
  fi
}

gcod "$@"

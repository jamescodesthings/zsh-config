#!/usr/bin/env zsh

# gcom: Checks out main
function gcom () {
  local DEPS=(
    git
  )

  if ! deps $DEPS; then
    return
  fi

  MAIN_BRANCH=$(git config gitflow.branch.main)
  if is empty "$MAIN_BRANCH"; then
    MAIN_BRANCH=main
  fi

  git checkout $MAIN_BRANCH
  if is not equal "$?" "0"; then
    echo "$c[error]Could not checkout main branch ($MAIN_BRANCH)\n$c[reset]"
    echo "$c[sub]to set the main branch for this repo:$c[reset]"
    echo "git config gitflow.branch.main $c[flag]main$c[reset]"
    return 1
  fi
}

gcom "$@"

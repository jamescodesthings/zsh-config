#!/usr/bin/env bash
# Diagnose window management environment. Checks extension, fallbacks, and tools.
# Prints a fix command if the extension is not working.
# Usage: window-debug-env

ok()   { printf "  [ok]   %s\n" "$*"; }
warn() { printf "  [warn] %s\n" "$*"; }
fail() { printf "  [fail] %s\n" "$*"; }

EXT_UUID="window-list@personal"
EXT_PATH="$HOME/.local/share/gnome-shell/extensions/$EXT_UUID"

echo "=== Display ==="
[[ -n "${WAYLAND_DISPLAY:-}" ]] && ok "Wayland: $WAYLAND_DISPLAY" || warn "WAYLAND_DISPLAY not set"
[[ -n "${DISPLAY:-}" ]]         && ok "X11: $DISPLAY"             || warn "DISPLAY not set"

echo ""
echo "=== Tools ==="
for tool in gdbus wmctrl xdotool xprop gnome-extensions; do
    command -v "$tool" &>/dev/null && ok "$tool: $(command -v $tool)" || fail "$tool: not found"
done

echo ""
echo "=== Extension: $EXT_UUID ==="
_ext_ok=false
if [[ -e "$EXT_PATH" ]]; then
    ok "installed: $EXT_PATH"
else
    fail "not installed: $EXT_PATH"
fi

if command -v gnome-extensions &>/dev/null; then
    if gnome-extensions list --enabled 2>/dev/null | grep -q "^$EXT_UUID$"; then
        ok "enabled"
    else
        fail "not enabled — run: gnome-extensions enable $EXT_UUID"
    fi
fi

if command -v gdbus &>/dev/null; then
    result=$(gdbus call --session \
        --dest com.personal.WindowList \
        --object-path /com/personal/WindowList \
        --method com.personal.WindowList.GetWindows 2>&1)
    if [[ "$result" == "('"* ]]; then
        ok "D-Bus endpoint responds — extension is working"
        _ext_ok=true
    else
        fail "D-Bus endpoint not responding: $result"
    fi
fi

echo ""
echo "=== Fallback: gdbus Eval (org.gnome.Shell.Eval) ==="
if command -v gdbus &>/dev/null && [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
    result=$(gdbus call --session \
        --dest org.gnome.Shell \
        --object-path /org/gnome/Shell \
        --method org.gnome.Shell.Eval \
        "1+1" 2>&1)
    if [[ "$result" == "(true,"* ]]; then
        ok "Eval works (unsafe_mode enabled)"
    elif [[ "$result" == "(false,"* ]]; then
        warn "Eval disabled — unsafe_mode not set (expected on GNOME 42+)"
    else
        fail "Eval error: $result"
    fi
else
    warn "gdbus or Wayland not available — skipping Eval check"
fi

echo ""
echo "=== Fallback: org.gnome.Shell.Introspect.GetWindows ==="
if command -v gdbus &>/dev/null; then
    result=$(gdbus call --session \
        --dest org.gnome.Shell \
        --object-path /org/gnome/Shell/Introspect \
        --method org.gnome.Shell.Introspect.GetWindows 2>&1)
    if [[ "$result" == *"AccessDenied"* ]]; then
        warn "GetWindows: AccessDenied (blocked by GNOME 42+ policy — expected)"
    elif [[ "$result" == *"Error"* ]]; then
        fail "GetWindows: $result"
    else
        ok "GetWindows works"
    fi
fi

echo ""
echo "=== Fallback: XWayland windows (xdotool+xprop) ==="
if command -v xdotool &>/dev/null && command -v xprop &>/dev/null; then
    count=0
    while IFS= read -r wid; do
        cls=$(xprop -id "$wid" WM_CLASS 2>/dev/null | grep -v "not found" | grep -oP '"[^"]+"' | head -1 | tr -d '"')
        name=$(xdotool getwindowname "$wid" 2>/dev/null)
        [[ -n "$cls" ]] || continue
        printf "  %s  %-25s  %s\n" "$wid" "$cls" "$name"
        ((count++))
    done < <(xdotool search --class "" 2>/dev/null)
    [[ $count -eq 0 ]] && warn "No XWayland windows with WM_CLASS found"
else
    warn "xdotool or xprop not available"
fi

echo ""
echo "=== Summary ==="
if $_ext_ok; then
    ok "Extension working — window scripts will function correctly on Wayland"
else
    fail "Extension not working — window scripts will fall back to XWayland-only (wmctrl)"
    echo ""
    echo "  Fix:"
    if [[ ! -e "$EXT_PATH" ]]; then
        echo "    Run the installer (from your zsh-config repo):"
        echo "      ./installers/gnome-extension-window-list"
        echo "    Then log out and back in."
    else
        echo "    Extension is installed but not responding."
        echo "    1. Enable it:    gnome-extensions enable $EXT_UUID"
        echo "    2. Log out and back in (Wayland — no in-place shell restart)."
        echo "    3. Re-run:       window-debug-env"
    fi
fi
